# SpendLens Environment Variables
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

# ─── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Groq (optional — fallback summary used if absent) ───────────────────────
# Free tier: https://console.groq.com — generous limits, no credit card needed
GROQ_API_KEY=gsk_...

# ─── Resend (optional — email skipped if absent) ─────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=audits@spendlens.co

# ─── App config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://spendlens.co
# For local dev: NEXT_PUBLIC_APP_URL=http://localhost:3000
